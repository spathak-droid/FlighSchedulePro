# =============================================================================
# Agentic Scheduler — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for your environment.

# -----------------------------------------------------------------------------
# FSP API Configuration
# -----------------------------------------------------------------------------

# FSP authentication endpoint (API Management gateway)
FSP_API_BASE_URL=https://development-fsp.azure-api.net

# FSP API base URL (direct API)
FSP_CORE_BASE_URL=https://api-develop.flightschedulepro.com

# FSP curriculum API base URL
FSP_CURRICULUM_BASE_URL=https://curriculum-api-develop.flightschedulepro.com

# FSP subscription key — required for all FSP API requests (x-subscription-key header)
FSP_SUBSCRIPTION_KEY=your-subscription-key

# FSP environment identifier
# Values: develop
FSP_ENVIRONMENT=develop

# -----------------------------------------------------------------------------
# Database (Railway or local)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Railway: postgresql://postgres:<password>@autorack.proxy.rlwy.net:<port>/railway
# Local:   postgresql://postgres:postgres@localhost:5432/fsp_scheduler
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fsp_scheduler

# -----------------------------------------------------------------------------
# Redis (Railway or local)
# -----------------------------------------------------------------------------

# Redis connection (used by BullMQ + weather cache)
# Railway: redis://default:<password>@autorack.proxy.rlwy.net:<port>
# Local:   redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------

# Secret used to sign and verify JWT tokens — must be a strong random string (min 32 chars)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Token expiration time (default: 8h)
# Accepts: '60s', '15m', '1h', '8h', '7d'
JWT_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# Mock Mode
# -----------------------------------------------------------------------------

# Set to 'true' to replace real FSP API calls with mock data.
# When enabled:
#   - All FspAuthService, FspScheduleService, FspResourceService, and
#     FspTrainingService methods return canned mock data
#   - The suggestions table is seeded with realistic test data on startup
#   - All mock calls are logged with a [MOCK] prefix
# Leave unset or set to 'false' for production FSP integration.
FSP_MOCK_MODE=false

# -----------------------------------------------------------------------------
# AI Configuration (OpenRouter + OpenAI)
# -----------------------------------------------------------------------------

# OpenRouter API key — used for AI-generated rationale and risk assessment
# Get yours at https://openrouter.ai/keys
OPEN_ROUTER_API_KEY=your-openrouter-key
OPEN_ROUTER_MODEL=anthropic/claude-haiku-4.5

# OpenAI API key — fallback if OpenRouter is unavailable
OPENAI_API_KEY=your-openai-key
OPEN_AI_MODEL=gpt-4.1-nano

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# AES-256 key for encrypting sensitive data at rest (fspToken, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank to disable encryption (NOT recommended for production)
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

